# Copy to .env and fill in to enable optional features.
# Leave blank/unset and sift simply skips those signals.

# --- Enrichment API keys (optional) ----------------------------------------
ABUSEIPDB_KEY=
VIRUSTOTAL_KEY=

# --- Webhook authentication (recommended in production) --------------------
# All /webhook/* POSTs must include: X-Sift-Webhook-Token: <token>
# SIFT_WEBHOOK_TOKEN=change-me

# --- Outbound notifications (optional) -------------------------------------
# ESCALATE_WEBHOOK_URL=https://hooks.slack.com/services/...
# THEHIVE_URL=https://thehive.example.org
# THEHIVE_API_KEY=
# SERVICENOW_INSTANCE=https://dev12345.service-now.com
# SERVICENOW_USER=sift-integration
# SERVICENOW_PASSWORD=
# SERVICENOW_ASSIGNMENT_GROUP=Security Operations

# --- Local blocklist (optional, no internet needed) ------------------------
# SIFT_LOCAL_BLOCKLIST=blocklist.txt

# --- Server overrides (optional) -------------------------------------------
# SIFT_HOST=127.0.0.1
# SIFT_PORT=8000
# SIFT_DB=sift.db
