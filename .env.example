# Copy to .env and fill in to enable optional enrichment signals.
# Leave blank/unset and sift simply skips those signals.

ABUSEIPDB_KEY=
VIRUSTOTAL_KEY=

# Optional: a local IP blocklist file (one IP per line, '#' comments) for
# fully air-gapped use — no key needed, works with no internet access at all.
# SIFT_LOCAL_BLOCKLIST=blocklist.txt

# Optional server overrides
# SIFT_HOST=127.0.0.1
# SIFT_PORT=8000
# SIFT_DB=sift.db
